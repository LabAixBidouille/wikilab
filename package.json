{
  "name": "wikilab-tooling",
  "version": "0.0.0",
  "private": true,
  "description": "Outils de qualité (linters, hooks, formatage) pour le repo Wiki@LAB. Le site Docusaurus vit dans site/.",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint \"**/*.md\" --ignore-path .markdownlintignore",
    "lint:md:fix": "markdownlint --fix \"**/*.md\" --ignore-path .markdownlintignore",
    "lint:spell": "cspell --no-must-find-files",
    "lint:links": "docker run --rm -v $PWD:/input lycheeverse/lychee --config /input/.lychee.toml '/input/site/docs/**/*.md' '/input/README.md'",
    "site:start": "npm --prefix site start",
    "site:build": "npm --prefix site run build",
    "site:typecheck": "npm --prefix site run typecheck",
    "site:clean": "rm -rf site/build site/.docusaurus site/.cache-loader && find site/src -name '*.js' -type f -delete",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@cspell/dict-fr-fr": "^2.2.4",
    "cspell": "^8.16.0",
    "git-precommit-checks": "^3.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "markdownlint-cli": "^0.43.0",
    "prettier": "^3.3.3",
    "validate-branch-name": "^1.3.1"
  },
  "lint-staged": {
    "*.md": [
      "prettier --check",
      "markdownlint",
      "cspell --no-must-find-files"
    ],
    "*.{js,jsx,ts,tsx}": [
      "prettier --check"
    ],
    "*.{json,css,yml,yaml}": "prettier --check"
  }
}
